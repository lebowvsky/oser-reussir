# PostgreSQL
POSTGRES_USER=oser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=oser_reussir
DATABASE_URL=postgres://oser:changeme@postgres:5432/oser_reussir

# Backend
NODE_ENV=development
JWT_SECRET=change_this_jwt_secret_in_prod
BACKEND_PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend
NUXT_PUBLIC_API_BASE=http://localhost:4000
NUXT_API_BASE_SERVER=http://backend:4000

# Backoffice (utilise le nom du service Docker, pas localhost)
VITE_API_BASE_URL=http://backend:4000

# Admin (premier compte, utilise au seed initial)
ADMIN_EMAIL=admin@oser-reussir.fr
ADMIN_PASSWORD=changeme_in_production
